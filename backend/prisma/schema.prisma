generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  USER
  SALON
  ADMIN
}

enum SalonStatus {
  PENDING
  APPROVED
  REJECTED
  DISABLED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  REJECTED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ─── Core Identity ───────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  phone         String?
  profileImage  String?
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  addresses     Address[]
  appointments  Appointment[]
  beautyProfile BeautyProfile?
  conversations Conversation[]
  orders        Order[]
  reviews       Review[]
  salon         Salon?
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String   @default("Home")
  fullName  String   @default("")
  phone     String   @default("")
  line1     String
  line2     String?
  landmark  String?
  city      String
  state     String
  pincode   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model BeautyProfile {
  userId            String   @id
  skinType          String?
  hairType          String?
  skinConcerns      String[] @default([])
  hairConcerns      String[] @default([])
  preferredBrands   String[] @default([])
  budgetRange       String?
  preferredServices String[] @default([])
  beautyGoals       String[] @default([])
  notes             String?
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Salon ───────────────────────────────────────────────────

model Salon {
  id            String       @id @default(cuid())
  userId        String       @unique
  slug          String       @unique
  name          String
  ownerName     String
  email         String
  phone         String
  description   String       @default("")
  address       String       @default("")
  city          String       @default("Bangalore")
  fulfillmentAddress String  @default("")
  services      String[]     @default([])
  timings       String       @default("10:00-21:00")
  coverImage    String?
  galleryImages String[]     @default([])
  website       String?
  instagram     String?
  rating        Float        @default(0)
  startingPrice Int          @default(0)
  status        SalonStatus  @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([city])
}

// ─── AI ──────────────────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

// ─── Commerce ────────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  userId         String
  total          Float
  paymentMethod  String
  addressId      String?
  status         OrderStatus @default(PENDING)
  trackingNumber String?
  createdAt      DateTime    @default(now())
  address        Address?    @relation(fields: [addressId], references: [id])
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@index([userId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  brand       String
  category    String
  price       Float
  rating      Float    @default(4.8)
  image       String
  gallery     String[] @default([])
  description String   @default("")
  ingredients String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Appointments ────────────────────────────────────────────

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  salonId       String
  service       String
  date          DateTime
  time          String
  startTime     String?
  endTime       String?
  notes         String?
  paymentMethod String            @default("PAY_AT_SALON")
  status        AppointmentStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  review        Review?

  @@index([userId])
  @@index([salonId])
}

model Review {
  id            String      @id @default(cuid())
  rating        Int
  comment       String
  salonId       String
  userId        String
  appointmentId String      @unique
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([salonId])
  @@index([userId])
}

// ─── Journal ─────────────────────────────────────────────────

model JournalArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String   @default("")
  category    String
  cover       String
  readingTime String   @default("5 min")
  content     String[] @default([])
  author      String   @default("Aûra Editorial")
  date        String
  isFeatured  Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
